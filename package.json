{
  "name": "promptmetrics",
  "version": "1.1.0",
  "description": "Lightweight, self-hosted prompt registry with versioning, metadata logging, evaluations, and multi-tenant observability",
  "main": "dist/server.js",
  "bin": {
    "promptmetrics-server": "dist/server.js",
    "promptmetrics": "dist/cli/promptmetrics-cli.js"
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias && tsc migrations/*.ts --rootDir . --outDir dist --declaration false",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write ./src",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "db:init": "ts-node -r tsconfig-paths/register src/scripts/init-db.ts",
    "migrate": "ts-node -r tsconfig-paths/register src/scripts/migrate.ts",
    "api-key:generate": "ts-node -r tsconfig-paths/register src/scripts/generate-api-key.ts"
  },
  "keywords": [
    "prompts",
    "llm",
    "versioning",
    "github",
    "metadata",
    "observability"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist/",
    "migrations/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/hpp": "^0.2.6",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/mustache": "^4.2.6",
    "@types/node": "^24.6.0",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/umzug": "^2.3.9",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.36.0",
    "jest": "^29.7.0",
    "nock": "^14.0.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "swagger-parser": "^10.0.3",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@types/axios": "^0.9.36",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.1.1",
    "commander": "^13.1.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "joi": "^18.0.1",
    "js-yaml": "^4.1.0",
    "lru-cache": "^11.3.5",
    "mustache": "^4.2.0",
    "opossum": "^5.0.1",
    "pg": "^8.20.0",
    "simple-git": "^3.36.0",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.2"
  }
}
