PORT=3000
NODE_ENV=development
API_KEY_SALT=change-me-in-production

# --- Auth ---
# API_KEY_LAST_USED_DEBOUNCE_MS=60000   # Minimum ms between last_used_at writes (default: 60000)

DRIVER=filesystem
SQLITE_PATH=./data/promptmetrics.db
GITHUB_REPO=
GITHUB_TOKEN=
GITHUB_SYNC_INTERVAL_MS=60000

# --- Rate Limiting ---
# RATE_LIMIT_WINDOW_MS=60000        # Time window in ms (default: 60000)
# RATE_LIMIT_MAX_REQUESTS=100       # Max requests per window (default: 100)
#                                   # Increase in CI/test: RATE_LIMIT_MAX_REQUESTS=10000

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
